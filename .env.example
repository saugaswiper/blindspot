# Copy this file to .env.local and fill in your values.
# NEVER commit .env.local to git.

# Supabase — get these from your project dashboard → Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# Server-only keys — NEVER use NEXT_PUBLIC_ prefix on these
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here
GEMINI_API_KEY=your-google-ai-studio-key-here
NCBI_API_KEY=your-ncbi-key-here
OPENALEX_EMAIL=your-email@example.com

# Resend — for emailing reports. Get a key at https://resend.com
# Without this, the "Email report" button will show a friendly error.
RESEND_API_KEY=your-resend-key-here
